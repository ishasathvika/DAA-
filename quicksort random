#include <stdio.h>
#include <stdlib.h>
#include <time.h>

void quick(int a[], int l, int h) {
    if (l >= h) return;

    int randIndex = l + rand() % (h - l + 1);
    int temp = a[l]; a[l] = a[randIndex]; a[randIndex] = temp;

    int pivot = a[l]; // first element now is random
    int i = l + 1, j = h;

    while (i <= j) {
        while (i <= h && a[i] <= pivot) i++;
        while (a[j] > pivot) j--;
        if (i < j) {
            temp = a[i]; a[i] = a[j]; a[j] = temp;
        }
    }

    temp = a[l]; a[l] = a[j]; a[j] = temp;

    quick(a, l, j - 1);
    quick(a, j + 1, h);
}

int main() {
    int n, i, a[20];
    srand(time(0)); // initialize random seed
    scanf("%d", &n);
    for (i = 0; i < n; i++) scanf("%d", &a[i]);

    quick(a, 0, n - 1);

    for (i = 0; i < n; i++) printf("%d ", a[i]);
    return 0;
}
