#include <stdio.h>

void quick(int a[], int l, int h) {
    if (l >= h) return;

    int pivot = a[h]; // last element as pivot
    int i = l, j = h - 1, temp;

    while (i <= j) {
        while (i <= j && a[i] <= pivot) i++;
        while (j >= l && a[j] > pivot) j--;
        if (i < j) {
            temp = a[i]; a[i] = a[j]; a[j] = temp;
        }
    }

    temp = a[i]; a[i] = a[h]; a[h] = temp;

    quick(a, l, i - 1);
    quick(a, i + 1, h);
}

int main() {
    int n, i, a[20];
    scanf("%d", &n);
    for (i = 0; i < n; i++) scanf("%d", &a[i]);

    quick(a, 0, n - 1);

    for (i = 0; i < n; i++) printf("%d ", a[i]);
    return 0;
}
