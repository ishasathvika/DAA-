#include<stdio.h>
#define n 4
#define INF 999

int main(){
    int cost[n][n],dist[n],i,j;

    for(i=0;i<n;i++)
        for(j=0;j<n;j++)
            scanf("%d",&cost[i][j]);

    dist[n-1]=0;

    for(i=n-2;i>=0;i--){
        dist[i]=INF;

        for(j=i+1;j<n;j++)
            if(cost[i][j]+dist[j]<dist[i])
                dist[i]=cost[i][j]+dist[j];
    }

    printf("%d",dist[0]);
}
