#include <stdio.h>

#define N 5

int visited[N];
int adj[N][N];

void dfs(int node, int n) {
    int i;
    visited[node] = 1;
    printf("%d ", node);

    for (i = 0; i < n; i++) {
        if (adj[node][i] && !visited[i])
            dfs(i, n);
    }
}

int main() {
    int n, i, j, start;

    printf("Enter number of vertices (max %d): ", N);
    scanf("%d", &n);

    printf("Enter adjacency matrix:\n");
    for (i = 0; i < n; i++)
        for (j = 0; j < n; j++)
            scanf("%d", &adj[i][j]);

    printf("Enter starting vertex: ");
    scanf("%d", &start);

    printf("DFS traversal: ");
    for (i = 0; i < n; i++) visited[i] = 0;

    dfs(start, n);
    printf("\n");
    return 0;
}
