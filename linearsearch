#include<stdio.h>
int main(){
    int a[10],n,i,key;

    scanf("%d",&n);
    for(i=0;i<n;i++) scanf("%d",&a[i]);

    printf("Enter key: ");
    scanf("%d",&key);

    for(i=0;i<n;i++)
        if(a[i]==key){
            printf("Found at %d",i);
            return 0;
        }

    printf("Not found");
}
