#include <stdio.h>

int w[20], x[20];
int n, m;

void sumOfSubsets(int i, int weight, int total) {
    if (weight == m) {
        printf("Subset: ");
        for (int j = 0; j < i; j++) {
            if (x[j] == 1)
                printf("%d ", w[j]);
        }
        printf("\n");
        return;
    }

    if (i == n || weight > m)
        return;

   
    x[i] = 1;
    sumOfSubsets(i + 1, weight + w[i], total - w[i]);

   
    x[i] = 0;
    sumOfSubsets(i + 1, weight, total - w[i]);
}

int main() {
    int total = 0;

    printf("Enter number of elements: ");
    scanf("%d", &n);

    printf("Enter elements:\n");
    for (int i = 0; i < n; i++) {
        scanf("%d", &w[i]);
        total += w[i];
    }

    printf("Enter required sum: ");
    scanf("%d", &m);

    sumOfSubsets(0, 0, total);

    return 0;
}
